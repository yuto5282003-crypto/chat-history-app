# ========================================
# SLOTY 環境変数
# ========================================

# ---------- デモモード ----------
# 1 にすると DB/認証/Stripe なしで UI 確認可能
NEXT_PUBLIC_DEMO_MODE=0

# ---------- Database（デモ時は不要） ----------
# DATABASE_URL="postgresql://user:password@localhost:5432/sloty?schema=public"

# ---------- NextAuth（デモ時は不要） ----------
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="your-secret-here"

# ---------- Google OAuth（デモ時は不要） ----------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---------- Stripe（デモ時は不要） ----------
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ---------- Resend（メール送信） ----------
# https://resend.com でAPIキーを取得
RESEND_API_KEY=""
# 送信元アドレス（Resendで認証済みドメイン or onboarding@resend.dev）
EMAIL_FROM="SLOTY <onboarding@resend.dev>"

# ---------- デモ入口（合言葉） ----------
# 空の場合「デモで入る」ボタンは非表示
NEXT_PUBLIC_DEMO_ENTRY_KEY="sloty-demo"

# ---------- 管理画面（Owner） ----------
# Owner判定用メールアドレス
OWNER_EMAIL="demo@sloty.app"
# 管理画面ログイン用パスコード（必須）
ADMIN_PASSCODE="sloty2024"
# KYC画像保管期限（日）
RETENTION_DAYS=180
