# ========================================
# Affi OS 環境変数
# ========================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------- AI Provider ----------
# Claude API (primary)
ANTHROPIC_API_KEY=""
# OpenAI API (alternative)
OPENAI_API_KEY=""
# 使用するAIプロバイダー: claude | openai
AI_PROVIDER="claude"

# ---------- X (Twitter) API ----------
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""

# ---------- アプリ設定 ----------
# デモモード: 1でダミーデータ使用、DB不要
NEXT_PUBLIC_DEMO_MODE=1
# タイムゾーン
TZ="Asia/Tokyo"
# Cron用シークレット
CRON_SECRET="your-cron-secret"

# ---------- Vercel ----------
# Vercel Cron Jobs用(vercel.jsonで設定)
